{
  "JwtSettings": {
    "Secret": "your-256-bit-secret-key-here-minimum-32-chars!!",
    "Issuer": "ChatBot.API",
    "Audience": "ChatBot.Client",
    "ExpirationMinutes": 60
  },
  "AiServiceSettings": {
    "BaseUrl": "http://localhost:8000",
    "TimeoutSeconds": 30,
    "RetryCount": 3
  },
  "RateLimitSettings": {
    "PermitLimit": 10,
    "WindowSeconds": 60
  },
  "Serilog": {
    "MinimumLevel": "Information",
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/chatbot-.txt",
          "rollingInterval": "Day"
        }
      }
    ]
  },
  "AllowedHosts": "*"
}
